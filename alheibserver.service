[Unit]
Description=Al-Heib School Management Server
After=network.target

[Service]
Type=simple
User=iico
WorkingDirectory=/home/iico/alheibschooliico
Environment=PORT=8080
Environment=NODE_ENV=production
ExecStart=/usr/bin/node /home/iico/alheibschooliico/dist/server.cjs
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
